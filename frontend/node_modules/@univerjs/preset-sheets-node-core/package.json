  },
  "homepage": "https://univer.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/dream-num/univer-presets"
  },
  "bugs": {
    "url": "https://github.com/dream-num/univer-presets/issues"
  },
  "keywords": [
    "univer"
  ],
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "import": "./lib/es/index.js",
      "require": "./lib/cjs/index.js",
      "types": "./lib/types/index.d.ts"
    },
    "./*": {
      "import": "./lib/es/*",
      "require": "./lib/cjs/*",
      "types": "./lib/types/index.d.ts"
    },
    "./locales/*": {
      "import": "./lib/es/locales/*.js",
      "require": "./lib/cjs/locales/*.js",
      "types": "./lib/types/locales/*.d.ts"
    },
    "./lib/*": "./lib/*"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./lib/es/index.js",
  "directories": {
    "lib": "lib"
  },
  "files": [
    "lib"
  ],
  "peerDependencies": {
    "react": "^16.9.0 || ^17.0.0 || ^18.0.0",
    "rxjs": ">=7.0.0"
  },
  "dependencies": {
    "@univerjs/docs": "0.5.5",
    "@univerjs/engine-formula": "0.5.5",
    "@univerjs/engine-render": "0.5.5",
    "@univerjs/rpc-node": "0.5.5",
    "@univerjs/sheets": "0.5.5",
    "@univerjs/sheets-data-validation": "0.5.5",
    "@univerjs/sheets-drawing": "0.5.5",
    "@univerjs/sheets-filter": "0.5.5",
    "@univerjs/sheets-formula": "0.5.5",
    "@univerjs/sheets-hyper-link": "0.5.5",
    "@univerjs/sheets-numfmt": "0.5.5",
    "@univerjs/sheets-sort": "0.5.5",
    "@univerjs/sheets-thread-comment": "0.5.5",
    "@univerjs/thread-comment": "0.5.5"
  },
  "devDependencies": {
    "@univerjs/core": "0.5.5",
    "typescript": "^5.7.2",
    "@univerjs-infra/shared": "0.5.5"
  },
  "scripts": {
    "prebuild:preset": "tsx prepare.ts",
    "build:preset": "tsx build.ts",
    "lint:types": "tsc --noEmit"
  },
  "module": "./lib/es/index.js"
}